# Copy this file to .env and fill in your values.
# Docker Compose reads .env automatically from the project directory.

# PS5 transfer address (IP:port — the payload's FTX2 listener)
PS5_ADDR=192.168.1.x:9113

# Host path to your game library (mounted read-only at /games inside the container)
GAMES_PATH=/mnt/games

# Host directory where engine logs are written
LOGS_PATH=./logs
